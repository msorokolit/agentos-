{
  "title": "AgenticOS — Overview",
  "uid": "agenticos-overview",
  "schemaVersion": 38,
  "version": 1,
  "tags": ["agenticos"],
  "timezone": "browser",
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "query": "label_values(up, job)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "type": "stat",
      "title": "Services up",
      "id": 1,
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "expr": "sum(up{job=~\"api-gateway|agent-runtime|llm-gateway|tool-registry|knowledge-svc|memory-svc\"})",
          "legendFormat": "up"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "green", "value": 6 }
            ]
          }
        }
      }
    },
    {
      "type": "timeseries",
      "title": "Request rate (RPS) by service",
      "id": 2,
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total{job=~\"$job\"}[1m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Error rate (4xx/5xx) by service",
      "id": 3,
      "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (job) (rate(http_requests_total{job=~\"$job\",status=~\"5..|4[03-9]\"}[1m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "p95 request latency by service",
      "id": 4,
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, job) (rate(http_request_duration_seconds_bucket{job=~\"$job\"}[5m])))",
          "legendFormat": "{{job}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "type": "timeseries",
      "title": "LLM token throughput (in/out)",
      "id": 5,
      "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (direction) (rate(tokens_total[5m]))",
          "legendFormat": "{{direction}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Tool invocations by tool (ok=true)",
      "id": 6,
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by (tool) (rate(tool_invocations_total{ok=\"true\"}[5m]))",
          "legendFormat": "{{tool}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Daily token spend (workspace)",
      "id": 7,
      "gridPos": { "x": 0, "y": 24, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "sum by (workspace_id) (increase(tokens_total[1d]))",
          "legendFormat": "{{workspace_id}}"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Audit events / minute",
      "id": 8,
      "gridPos": { "x": 8, "y": 24, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "sum(rate(audit_events_total[1m])) * 60"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Policy denies (15m)",
      "id": 9,
      "gridPos": { "x": 16, "y": 24, "w": 8, "h": 4 },
      "targets": [
        {
          "expr": "sum(increase(policy_decisions_total{decision=\"deny\"}[15m]))"
        }
      ]
    }
  ]
}
