# -----------------------------------------------------------------------------
# AgenticOS — example environment file. Copy to `.env` and edit.
# -----------------------------------------------------------------------------

# --- Core ---
AGENTICOS_ENV=development
AGENTICOS_LOG_LEVEL=INFO
AGENTICOS_SECRET_KEY=change-me-in-prod-please-32bytes-min

# --- Postgres ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=agenticos
POSTGRES_PASSWORD=agenticos
POSTGRES_DB=agenticos
DATABASE_URL=postgresql+psycopg://agenticos:agenticos@postgres:5432/agenticos

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- NATS ---
NATS_URL=nats://nats:4222

# --- MinIO / S3 ---
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=agenticos
S3_SECRET_KEY=agenticos-minio
S3_BUCKET=agenticos
S3_REGION=us-east-1

# --- OIDC (Keycloak dev defaults) ---
OIDC_ISSUER=http://keycloak:8080/realms/agenticos
OIDC_CLIENT_ID=agenticos-web
OIDC_CLIENT_SECRET=dev-client-secret
OIDC_REDIRECT_URI=http://localhost:8080/api/v1/auth/oidc/callback

# --- LLM defaults ---
OLLAMA_URL=http://ollama:11434
DEFAULT_CHAT_MODEL_ALIAS=chat-default
DEFAULT_EMBED_MODEL_ALIAS=embed-default
EMBED_DIM=768

# --- OPA ---
OPA_URL=http://opa:8181

# --- OTel ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAMESPACE=agenticos

# --- Web UI ---
NEXT_PUBLIC_API_URL=http://localhost:8080
WEB_UI_PORT=3000

# --- Service ports (host) ---
API_GATEWAY_PORT=8080
LLM_GATEWAY_PORT=8081
AGENT_RUNTIME_PORT=8082
TOOL_REGISTRY_PORT=8083
KNOWLEDGE_PORT=8084
MEMORY_PORT=8085
